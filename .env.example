# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
PUBLIC_SITE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_BASE_URL=http://localhost:4000
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_SECONDS=2592000
CRON_SECRET=replace-with-at-least-24-random-characters
VAULT_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
# SHA-256 of the 4-digit vault PIN
VAULT_PIN_HASH=

# Supabase server-side access. Never expose SERVICE_ROLE_KEY to frontend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram bots
TELEGRAM_PARTICIPANT_BOT_TOKEN=
TELEGRAM_ORG_BOT_TOKEN=
PARTICIPANT_BOT_SERVICE_TOKEN=replace-with-at-least-24-random-characters
ORG_BOT_SERVICE_TOKEN=replace-with-at-least-24-random-characters
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400

# YouGile: one technical account/API key, stored only on the backend.
YOUGILE_BASE_URL=https://yougile.com/api-v2
YOUGILE_API_KEY=
YOUGILE_PROJECT_ID=
YOUGILE_DEFAULT_COLUMN_ID=
YOUGILE_WEBHOOK_SECRET=

# ITMO Events API (when credentials are issued)
ITMO_EVENTS_BASE_URL=
ITMO_EVENTS_API_KEY=
ITMO_EVENTS_WEBHOOK_SECRET=

# ITMO.ID OIDC. Fill when access is granted.
ITMO_ID_ISSUER_URL=
ITMO_ID_CLIENT_ID=
ITMO_ID_CLIENT_SECRET=
ITMO_ID_REDIRECT_URI=http://localhost:4000/auth/itmo/callback

# Temporary photo cleanup
TEMP_MEDIA_TTL_MINUTES=60
WORKER_ENABLED=false
WORKER_INTERVAL_SECONDS=30

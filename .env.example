# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
PUBLIC_SITE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_BASE_URL=http://localhost:4000

# Supabase server-side access. Never expose SERVICE_ROLE_KEY to frontend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram bots
TELEGRAM_PARTICIPANT_BOT_TOKEN=
TELEGRAM_ORG_BOT_TOKEN=
PARTICIPANT_BOT_SERVICE_TOKEN=replace-with-at-least-24-random-characters
ORG_BOT_SERVICE_TOKEN=replace-with-at-least-24-random-characters
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400

# YouGile: one technical account/API key, stored only on the backend.
YOUGILE_BASE_URL=https://yougile.com/api-v2
YOUGILE_API_KEY=
YOUGILE_PROJECT_ID=

# ITMO.ID OIDC. Fill when access is granted.
ITMO_ID_ISSUER_URL=
ITMO_ID_CLIENT_ID=
ITMO_ID_CLIENT_SECRET=
ITMO_ID_REDIRECT_URI=http://localhost:4000/auth/itmo/callback
